generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  KY_THUAT
  CAY_MO
  KHO_MO
  KHO_THANH_PHAM
  SALE
  MOI_TRUONG
  DIEU_PHOI
}

enum WarehouseType {
  SAN_XUAT
  THANH_PHAM
}

enum RoomType {
  // Kho sản xuất — "Kho sáng" gồm 2 phòng: mẫu mẹ (kệ gắn mã cây + nhân viên) và ra rễ (không ràng buộc)
  PHONG_MAU_ME
  PHONG_RA_RE
  PHONG_TOI
  // Kho thành phẩm
  PHONG_KHA_DUNG
  PHONG_THEO_DOI
  PHONG_HAN_TUI
  PHONG_THI_TRUONG
}

enum PlantStage {
  MAU_ME
  THANH_PHAM
}

enum LotStatus {
  ACTIVE
  TRANSFERRED
  CONTAMINATED
  DESTROYED
  PLANTED
  SOLD
}

enum InstructionStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TransferStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum MediumPurpose {
  MOTHER // pha để nhân thêm mẫu mẹ
  FINISHED // pha để ra rễ thành cây thành phẩm
}

enum OrderStatus {
  DRAFT
  HELD
  CONFIRMED
  SHIPPED
  CANCELLED
}

enum AlertType {
  CONTAMINATION_HIGH
  OUTPUT_DEVIATION
  ORDER_EXPIRING
  ORDER_EXPIRED
  STOCK_LOW
  LOT_READY_TRANSFER
  ORDER_PENDING_PACK
  MEDIUM_HANDOVER_READY
  MOTHER_LOT_READY
}

enum AlertStatus {
  UNREAD
  READ
  RESOLVED
}

// Nguyên nhân KY_THUAT chọn khi xử lý alert OUTPUT_DEVIATION — chỉ áp dụng cho loại alert này.
enum DeviationCause {
  KY_THUAT_SAI // Do nhân viên kỹ thuật ra chỉ định sai
  CAY_MO_SAI   // Do nhân viên cấy sai
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// USERS
// ============================================================

model User {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  email     String     @unique
  password  String
  role      UserRole?
  status    UserStatus @default(PENDING)
  isActive  Boolean    @default(true)
  holdDays  Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  plantingInstructions PlantingInstruction[] @relation("CreatedBy")
  assignedInstructions PlantingInstruction[] @relation("AssignedTo")
  dailyRecords         DailyRecord[]
  transfersFrom        Transfer[]            @relation("TransferFrom")
  transfersTo          Transfer[]            @relation("TransferTo")
  orders               Order[]
  alerts               Alert[]
  roomAccess           RoomAccess[]
  assignedShelves      Shelf[]                @relation("ShelfAssignedStaff")
  mediumHandoversFrom  MediumHandover[]       @relation("MediumHandoverFrom")
  mediumHandoversTo    MediumHandover[]       @relation("MediumHandoverTo")
  checklistItems       ChecklistItem[]

  @@map("users")
}

// Bật/tắt quyền truy cập từng trang (href) cho từng vai trò — quản lý qua UI Admin.
model RolePermission {
  id        String   @id @default(cuid())
  role      UserRole
  href      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, href])
  @@map("role_permissions")
}

// ============================================================
// SYSTEM CONFIG
// ============================================================

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

// ============================================================
// CHECKLIST — đầu việc hàng ngày theo vai trò
// ============================================================

// Danh mục đầu việc Admin soạn sẵn cho từng vai trò — mỗi ngày hệ thống tự sinh 1 ChecklistItem
// cho từng NV thuộc vai trò đó từ các template đang isActive.
model ChecklistTemplate {
  id        String   @id @default(cuid())
  role      UserRole
  title     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ChecklistItem[]

  @@map("checklist_templates")
}

// 1 dòng = 1 đầu việc đã giao cho 1 NV vào 1 ngày cụ thể (assignedDate). title chép lại từ template lúc
// sinh (không đổi ngược nếu sau này Admin sửa template). Việc chưa hoàn thành sẽ tiếp tục hiện ở checklist
// "hôm nay" của NV cho tới khi tích xong — không sinh thêm dòng mới cho cùng template khi còn dòng cũ
// đang PENDING, nên xem như tự động "dồn sang ngày hôm sau" mà không nhân bản.
model ChecklistItem {
  id           String            @id @default(cuid())
  templateId   String
  template     ChecklistTemplate @relation(fields: [templateId], references: [id])
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  title        String
  assignedDate DateTime // chỉ lấy phần ngày (00:00) — ngày đầu việc được sinh ra, dùng để thống kê theo ngày
  completed    Boolean           @default(false)
  completedAt  DateTime?
  createdAt    DateTime          @default(now())

  @@map("checklist_items")
}

// Ngưỡng % hoàn thành tối thiểu/ngày theo từng vai trò — Admin cấu hình, dùng để tô cảnh báo trên báo cáo.
model ChecklistThreshold {
  role       UserRole @id
  minPercent Int      @default(80)
  updatedAt  DateTime @updatedAt

  @@map("checklist_thresholds")
}

// ============================================================
// PLANT TYPES
// ============================================================

// Loại cây (nhóm chung) — mã 2 ký tự, VD: MT, AL, PD. Mỗi loại cây có nhiều "chi tiết loại cây"
// (PlantType) đánh số 001-999 bên trong.
model PlantCategory {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plantTypes PlantType[]

  @@map("plant_categories")
}

// Chi tiết loại cây (giống cây cụ thể) — mã đầy đủ = mã Loại cây (category.code) + số thứ tự 3 chữ số
// (seq, 001-999) trong danh mục đó, VD: "MT001". Đây là entity thực sự được dùng xuyên suốt hệ thống
// (Lot, Shelf, PlantingInstruction) — "Loại cây" (PlantCategory) chỉ là nhóm cha để phân loại và sinh
// mã tự động. Tỉ lệ nhân mẫu mẹ/ra rễ + môi trường KHÔNG có cấu hình mặc định ở đây — KY_THUAT tự nhập
// theo tình trạng thực tế của từng lô khi tạo chỉ định cấy (xem PlantingInstructionItem).
model PlantType {
  id                 String   @id @default(cuid())
  categoryId         String
  category           PlantCategory @relation(fields: [categoryId], references: [id])
  seq                Int // số thứ tự để sắp hiển thị trong Loại cây, không quyết định code
  code               String   @unique // category.code (2 ký tự, tự lấy theo Loại cây) + 3 ký tự NV nhập tay, VD: "MT001"
  name               String
  description        String?
  // Số tuần cố định (không phải khoảng min-max) do Admin cài đặt cho từng chi tiết loại cây.
  transferWaitWeeks  Int      @default(5) // Thời gian đợi cấy chuyển (mẫu mẹ) — dùng tính Lot.expectedMoveAt khi stage = MAU_ME
  rootingWeeks       Int      @default(5) // Thời gian ra rễ (thành phẩm) — dùng tính Lot.expectedMoveAt khi stage = THANH_PHAM
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lots                 Lot[]
  plantingInstructions PlantingInstruction[]
  shelves              Shelf[]

  @@unique([categoryId, seq])
  @@map("plant_types")
}

// ============================================================
// MEDIUM TYPES
// ============================================================

model MediumType {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  instructionItemsAsMotherMedium    PlantingInstructionItem[] @relation("ItemMotherMedium")
  instructionItemsAsFinishedMedium  PlantingInstructionItem[] @relation("ItemFinishedMedium")
  handoverItems                     MediumHandoverItem[]

  @@map("medium_types")
}

// ============================================================
// WAREHOUSES
// ============================================================

model Warehouse {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  type        WarehouseType
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  rooms        Room[]
  shelves      Shelf[]
  transfersIn  Transfer[] @relation("TransferTo")
  transfersOut Transfer[] @relation("TransferFrom")

  @@map("warehouses")
}

// ============================================================
// ROOMS — cả kho sản xuất (phòng sáng/phòng tối) và kho thành phẩm
// (phòng khả dụng/theo dõi/hàn túi/thị trường) đều dùng model này.
// ============================================================

model Room {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  type        RoomType
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shelves           Shelf[]
  transfersFromRoom Transfer[] @relation("TransferFromRoom")
  transfersToRoom   Transfer[] @relation("TransferToRoom")
  roomAccess        RoomAccess[]

  @@map("rooms")
}

// Cấp quyền xem 1 phòng cho 1 user cụ thể — dùng cho Phòng thị trường (SALE).
model RoomAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, roomId])
  @@map("room_access")
}

// ============================================================
// SHELVES
// ============================================================

model Shelf {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  // Luôn trỏ tới kho chứa kệ này (kể cả khi kệ nằm trong 1 room) — giữ để
  // các query/hiển thị hiện có dựa vào shelf.warehouse tiếp tục hoạt động.
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  // Có giá trị khi kệ nằm trong 1 phòng cụ thể (mọi kệ hiện nay đều vậy).
  // Để null nếu sau này có kệ gắn thẳng vào kho, không qua phòng nào.
  roomId      String?
  room        Room?     @relation(fields: [roomId], references: [id])
  rowNumber   Int?
  colNumber   Int?
  // Tối đa bao nhiêu (mẫu mẹ/túi) được xếp trên kệ này — kệ Phòng mẫu mẹ mặc định 360.
  capacity    Int?
  // Chỉ ràng buộc với kệ trong Phòng mẫu mẹ (SUPER_ADMIN cấu hình) — 1 kệ chỉ xếp 1 mã cây và
  // gắn với 1 nhân viên cấy mô cụ thể. Kệ Phòng ra rễ không dùng 2 field này (luôn null).
  plantTypeId String?
  plantType   PlantType? @relation(fields: [plantTypeId], references: [id])
  assignedStaffId String?
  assignedStaff   User?  @relation("ShelfAssignedStaff", fields: [assignedStaffId], references: [id])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lots             Lot[]
  instructionItems PlantingInstructionItem[]

  @@map("shelves")
}

// ============================================================
// LOTS
// ============================================================

model Lot {
  id              String     @id @default(cuid())
  // Không unique riêng lẻ — mã lô = mã cây + mã NV cấy + mã tuần/năm (VD "AL001003" + "0726"), NHIỀU lô có
  // thể dùng chung 1 mã nếu cùng chỉ định/tuần nhưng khác quy cách (M03 và M05 vẫn là 2 dòng Lot riêng,
  // chỉ đính cùng mã lô để NV nhìn biết chúng thuộc cùng 1 đợt cấy). Duy nhất theo (code, stageCode).
  code            String
  plantTypeId     String
  plantType       PlantType  @relation(fields: [plantTypeId], references: [id])
  stage           PlantStage
  stageCode       String

  shelfId         String?
  shelf           Shelf?     @relation(fields: [shelfId], references: [id])

  quantity        Int
  initialQuantity Int
  status          LotStatus  @default(ACTIVE)

  enteredAt       DateTime   @default(now())
  expectedMoveAt  DateTime?

  parentLotId     String?
  parentLot       Lot?       @relation("LotChildren", fields: [parentLotId], references: [id])
  childLots       Lot[]      @relation("LotChildren")

  instructionId   String?
  instruction     PlantingInstruction? @relation(fields: [instructionId], references: [id])

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  dailyRecordItems    DailyRecordItem[]
  transferItems       TransferItem[]
  orderItems          OrderItem[]
  contaminations      ContaminationRecord[]
  instructionItems    PlantingInstructionItem[]

  @@unique([code, stageCode])
  @@map("lots")
}

// ============================================================
// PLANTING INSTRUCTIONS
// ============================================================

model PlantingInstruction {
  id            String            @id @default(cuid())
  code          String            @unique
  plantTypeId   String
  plantType     PlantType         @relation(fields: [plantTypeId], references: [id])
  // Môi trường nay chọn riêng theo từng dòng quy cách nguồn (M3/M5) — xem PlantingInstructionItem,
  // vì mỗi quy cách có thể dùng môi trường nhân mẫu mẹ / ra rễ khác nhau.

  createdById   String
  createdBy     User              @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId  String?
  assignedTo    User?             @relation("AssignedTo", fields: [assignedToId], references: [id])

  // Tổng đầu vào/dự kiến cộng dồn từ tất cả các dòng quy cách nguồn (items) — 1 chỉ định có thể dùng nhiều
  // quy cách nguồn (VD: cùng 1 kệ có cả M3 và M5), mỗi dòng tự có tỉ lệ riêng — xem PlantingInstructionItem.
  inputMotherQuantity     Int
  expectedMotherOutput    Int?
  expectedFinishedOutput  Int?

  // Kế hoạch phân bổ thành phẩm dự kiến theo quy cách đóng gói — KY_THUAT nhập lúc tạo chỉ định,
  // tổng nên khớp expectedFinishedOutput. Lô thành phẩm thật sự tạo ra khi NV cấy nhập nhật ký hàng ngày
  // có thể mang quy cách T01 hoặc T05 tùy NV chọn — 2 số này chỉ là kế hoạch để đối chiếu.
  plannedT01Quantity      Int?
  plannedT05Quantity      Int?

  status      InstructionStatus @default(DRAFT)
  weekStart   DateTime?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  items               PlantingInstructionItem[]
  lots                Lot[]
  dailyRecords        DailyRecord[]
  mediumHandoverItems MediumHandoverItem[]

  @@map("planting_instructions")
}

// 1 dòng = 1 quy cách nguồn (M3 hoặc M5) dùng trong chỉ định. 1 kệ có thể sinh nhiều dòng
// (VD: kệ có cả M3 và M5) vì mỗi quy cách có tỉ lệ nhân/ra rễ riêng.
model PlantingInstructionItem {
  id            String              @id @default(cuid())
  instructionId String
  instruction   PlantingInstruction @relation(fields: [instructionId], references: [id])
  shelfId       String
  shelf         Shelf               @relation(fields: [shelfId], references: [id])
  lotId         String?
  lot           Lot?                @relation(fields: [lotId], references: [id])
  stageCode     String? // "M3" | "M5"
  quantity      Int

  motherSampleRatio      Float?
  rootingRatio           Float?
  expectedMotherOutput   Int?
  expectedFinishedOutput Int?

  // Môi trường riêng cho dòng quy cách này: 1 để nhân thêm mẫu mẹ, 1 để ra rễ thành cây thành phẩm.
  motherMediumTypeId     String?
  motherMedium           MediumType? @relation("ItemMotherMedium", fields: [motherMediumTypeId], references: [id])
  finishedMediumTypeId   String?
  finishedMedium         MediumType? @relation("ItemFinishedMedium", fields: [finishedMediumTypeId], references: [id])

  @@map("planting_instruction_items")
}

// ============================================================
// MEDIUM HANDOVERS — phiếu bàn giao môi trường đã pha (MOI_TRUONG -> CAY_MO)
// ============================================================

// Không dùng chung model Transfer vì môi trường không gắn với Lot/kệ/kho — chỉ là số lượng đã pha
// theo từng mã môi trường, bàn giao trực tiếp cho NV cấy phụ trách chỉ định cần dùng.
model MediumHandover {
  id         String         @id @default(cuid())
  code       String         @unique
  fromUserId String
  fromUser   User           @relation("MediumHandoverFrom", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User           @relation("MediumHandoverTo", fields: [toUserId], references: [id])
  status     TransferStatus @default(PENDING)
  notes      String?
  confirmedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  items MediumHandoverItem[]

  @@map("medium_handovers")
}

model MediumHandoverItem {
  id            String              @id @default(cuid())
  handoverId    String
  handover      MediumHandover      @relation(fields: [handoverId], references: [id])
  mediumTypeId  String
  mediumType    MediumType          @relation(fields: [mediumTypeId], references: [id])
  // Chỉ định liên quan (nếu có) — để NV cấy đối chiếu đúng phần môi trường của chỉ định nào.
  instructionId String?
  instruction   PlantingInstruction? @relation(fields: [instructionId], references: [id])
  purpose       MediumPurpose
  quantity      Int

  @@map("medium_handover_items")
}

// ============================================================
// DAILY RECORDS
// ============================================================

model DailyRecord {
  id            String              @id @default(cuid())
  instructionId String
  instruction   PlantingInstruction @relation(fields: [instructionId], references: [id])
  staffId       String
  staff         User                @relation(fields: [staffId], references: [id])
  recordDate    DateTime            @default(now())
  motherUsed    Int
  notes         String?
  createdAt     DateTime            @default(now())

  items DailyRecordItem[]

  @@map("daily_records")
}

model DailyRecordItem {
  id              String      @id @default(cuid())
  dailyRecordId   String
  dailyRecord     DailyRecord @relation(fields: [dailyRecordId], references: [id])
  lotId           String
  lot             Lot         @relation(fields: [lotId], references: [id])
  stage           PlantStage
  quantityCreated Int

  @@map("daily_record_items")
}

// ============================================================
// CONTAMINATION RECORDS
// ============================================================

model ContaminationRecord {
  id            String    @id @default(cuid())
  lotId         String
  lot           Lot       @relation(fields: [lotId], references: [id])
  quantity      Int
  recordDate    DateTime  @default(now())
  confirmedAt   DateTime?
  confirmedById String?
  notes         String?
  createdAt     DateTime  @default(now())

  @@map("contamination_records")
}

// ============================================================
// TRANSFERS
// ============================================================

model Transfer {
  id              String         @id @default(cuid())
  code            String         @unique
  fromWarehouseId String?
  fromWarehouse   Warehouse?     @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  fromRoomId      String?
  fromRoom        Room?          @relation("TransferFromRoom", fields: [fromRoomId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  toRoomId        String?
  toRoom          Room?          @relation("TransferToRoom", fields: [toRoomId], references: [id])
  fromUserId      String
  fromUser        User           @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUserId        String?
  toUser          User?          @relation("TransferTo", fields: [toUserId], references: [id])
  status          TransferStatus @default(PENDING)
  notes           String?
  transferredAt   DateTime       @default(now())
  confirmedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items TransferItem[]

  @@map("transfers")
}

model TransferItem {
  id         String   @id @default(cuid())
  transferId String
  transfer   Transfer @relation(fields: [transferId], references: [id])
  lotId      String
  lot        Lot      @relation(fields: [lotId], references: [id])
  quantity   Int
  notes      String?

  @@map("transfer_items")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id              String      @id @default(cuid())
  code            String      @unique
  saleId          String
  sale            User        @relation(fields: [saleId], references: [id])
  customerName    String
  customerPhone   String?
  customerAddress String?
  status          OrderStatus @default(DRAFT)
  holdUntil       DateTime?
  confirmedAt     DateTime?
  shippedAt       DateTime?
  cancelledAt     DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  lotId     String
  lot       Lot     @relation(fields: [lotId], references: [id])
  quantity  Int
  unitPrice Float?
  notes     String?

  @@map("order_items")
}

// ============================================================
// ALERTS
// ============================================================

model Alert {
  id          String      @id @default(cuid())
  type        AlertType
  status      AlertStatus @default(UNREAD)
  title       String
  message     String
  userId      String?
  targetRole  UserRole?
  user        User?       @relation(fields: [userId], references: [id])
  relatedId   String?
  relatedType String?
  cause       DeviationCause?
  createdAt   DateTime    @default(now())
  readAt      DateTime?

  @@map("alerts")
}
