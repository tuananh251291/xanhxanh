generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  KY_THUAT
  CAY_MO
  KHO_MO
  KHO_THANH_PHAM
  SALE
  MOI_TRUONG
  DIEU_PHOI
}

enum WarehouseType {
  SAN_XUAT
  THANH_PHAM
}

enum RoomType {
  // Kho sản xuất — "Kho sáng" gồm 2 phòng: mẫu mẹ (kệ gắn mã cây + nhân viên) và ra rễ (không ràng buộc)
  PHONG_MAU_ME
  PHONG_RA_RE
  PHONG_TOI
  // Kho thành phẩm
  PHONG_KHA_DUNG
  PHONG_THEO_DOI
  PHONG_HAN_TUI
  PHONG_THI_TRUONG
}

enum PlantStage {
  MAU_ME
  THANH_PHAM
}

enum LotStatus {
  ACTIVE
  TRANSFERRED
  CONTAMINATED
  DESTROYED
  PLANTED
  SOLD
}

enum InstructionStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TransferStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum OrderStatus {
  DRAFT
  HELD
  CONFIRMED
  SHIPPED
  CANCELLED
}

enum AlertType {
  CONTAMINATION_HIGH
  OUTPUT_DEVIATION
  ORDER_EXPIRING
  ORDER_EXPIRED
  STOCK_LOW
  LOT_READY_TRANSFER
  ORDER_PENDING_PACK
}

enum AlertStatus {
  UNREAD
  READ
  RESOLVED
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// USERS
// ============================================================

model User {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  email     String     @unique
  password  String
  role      UserRole?
  status    UserStatus @default(PENDING)
  isActive  Boolean    @default(true)
  holdDays  Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  plantingInstructions PlantingInstruction[] @relation("CreatedBy")
  assignedInstructions PlantingInstruction[] @relation("AssignedTo")
  dailyRecords         DailyRecord[]
  transfersFrom        Transfer[]            @relation("TransferFrom")
  transfersTo          Transfer[]            @relation("TransferTo")
  orders               Order[]
  alerts               Alert[]
  roomAccess           RoomAccess[]
  assignedShelves      Shelf[]                @relation("ShelfAssignedStaff")

  @@map("users")
}

// Bật/tắt quyền truy cập từng trang (href) cho từng vai trò — quản lý qua UI Admin.
model RolePermission {
  id        String   @id @default(cuid())
  role      UserRole
  href      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, href])
  @@map("role_permissions")
}

// ============================================================
// SYSTEM CONFIG
// ============================================================

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

// ============================================================
// PLANT TYPES
// ============================================================

model PlantType {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  description        String?
  lightRoomWeeksMin  Int      @default(4)
  lightRoomWeeksMax  Int      @default(6)
  finishedDaysMin    Int      @default(30)
  finishedDaysMax    Int      @default(45)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lots                 Lot[]
  plantingInstructions PlantingInstruction[]
  specs                PlantTypeSpec[]
  shelves              Shelf[]

  @@map("plant_types")
}

// ============================================================
// MEDIUM TYPES
// ============================================================

model MediumType {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  specsAsMotherMedium               PlantTypeSpec[]           @relation("SpecMotherMedium")
  specsAsFinishedMedium             PlantTypeSpec[]           @relation("SpecFinishedMedium")
  instructionItemsAsMotherMedium    PlantingInstructionItem[] @relation("ItemMotherMedium")
  instructionItemsAsFinishedMedium  PlantingInstructionItem[] @relation("ItemFinishedMedium")

  @@map("medium_types")
}

// Tỉ lệ nhân mẫu mẹ/ra rễ + môi trường mặc định theo từng quy cách mẫu mẹ (M3/M5) của mỗi loại cây.
// Mỗi quy cách có 2 môi trường riêng: 1 để nhân thêm mẫu mẹ, 1 để ra rễ thành cây thành phẩm — vì 2 giai
// đoạn này dùng công thức môi trường khác nhau. Dùng để tự động điền khi tạo chỉ định cấy — quét/chọn kệ
// nguồn ra quy cách (M3/M5) rồi tra bảng này theo (plantTypeId, stageCode).
model PlantTypeSpec {
  id                    String     @id @default(cuid())
  plantTypeId           String
  plantType             PlantType  @relation(fields: [plantTypeId], references: [id])
  stageCode             String // "M3" | "M5" — cụm 3 chồi / cụm 5 chồi
  motherSampleRatio     Float
  rootingRatio          Float
  // Optional ở tầng DB để thêm cột mới không phá dữ liệu cũ (16 dòng đã tồn tại) — tầng ứng dụng
  // (API /api/plant-type-specs, form cấu hình) vẫn bắt buộc nhập cả 2 khi tạo/sửa quy cách.
  motherMediumTypeId    String?
  motherMedium          MediumType? @relation("SpecMotherMedium", fields: [motherMediumTypeId], references: [id])
  finishedMediumTypeId  String?
  finishedMedium        MediumType? @relation("SpecFinishedMedium", fields: [finishedMediumTypeId], references: [id])
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([plantTypeId, stageCode])
  @@map("plant_type_specs")
}

// ============================================================
// WAREHOUSES
// ============================================================

model Warehouse {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  type        WarehouseType
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  rooms        Room[]
  shelves      Shelf[]
  transfersIn  Transfer[] @relation("TransferTo")
  transfersOut Transfer[] @relation("TransferFrom")

  @@map("warehouses")
}

// ============================================================
// ROOMS — cả kho sản xuất (phòng sáng/phòng tối) và kho thành phẩm
// (phòng khả dụng/theo dõi/hàn túi/thị trường) đều dùng model này.
// ============================================================

model Room {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  type        RoomType
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shelves           Shelf[]
  transfersFromRoom Transfer[] @relation("TransferFromRoom")
  transfersToRoom   Transfer[] @relation("TransferToRoom")
  roomAccess        RoomAccess[]

  @@map("rooms")
}

// Cấp quyền xem 1 phòng cho 1 user cụ thể — dùng cho Phòng thị trường (SALE).
model RoomAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, roomId])
  @@map("room_access")
}

// ============================================================
// SHELVES
// ============================================================

model Shelf {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  // Luôn trỏ tới kho chứa kệ này (kể cả khi kệ nằm trong 1 room) — giữ để
  // các query/hiển thị hiện có dựa vào shelf.warehouse tiếp tục hoạt động.
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  // Có giá trị khi kệ nằm trong 1 phòng cụ thể (mọi kệ hiện nay đều vậy).
  // Để null nếu sau này có kệ gắn thẳng vào kho, không qua phòng nào.
  roomId      String?
  room        Room?     @relation(fields: [roomId], references: [id])
  rowNumber   Int?
  colNumber   Int?
  // Tối đa bao nhiêu (mẫu mẹ/túi) được xếp trên kệ này — kệ Phòng mẫu mẹ mặc định 360.
  capacity    Int?
  // Chỉ ràng buộc với kệ trong Phòng mẫu mẹ (SUPER_ADMIN cấu hình) — 1 kệ chỉ xếp 1 mã cây và
  // gắn với 1 nhân viên cấy mô cụ thể. Kệ Phòng ra rễ không dùng 2 field này (luôn null).
  plantTypeId String?
  plantType   PlantType? @relation(fields: [plantTypeId], references: [id])
  assignedStaffId String?
  assignedStaff   User?  @relation("ShelfAssignedStaff", fields: [assignedStaffId], references: [id])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lots             Lot[]
  instructionItems PlantingInstructionItem[]

  @@map("shelves")
}

// ============================================================
// LOTS
// ============================================================

model Lot {
  id              String     @id @default(cuid())
  code            String     @unique
  plantTypeId     String
  plantType       PlantType  @relation(fields: [plantTypeId], references: [id])
  stage           PlantStage
  stageCode       String

  shelfId         String?
  shelf           Shelf?     @relation(fields: [shelfId], references: [id])

  quantity        Int
  initialQuantity Int
  status          LotStatus  @default(ACTIVE)

  enteredAt       DateTime   @default(now())
  expectedMoveAt  DateTime?

  parentLotId     String?
  parentLot       Lot?       @relation("LotChildren", fields: [parentLotId], references: [id])
  childLots       Lot[]      @relation("LotChildren")

  instructionId   String?
  instruction     PlantingInstruction? @relation(fields: [instructionId], references: [id])

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  dailyRecordItems    DailyRecordItem[]
  transferItems       TransferItem[]
  orderItems          OrderItem[]
  contaminations      ContaminationRecord[]
  instructionItems    PlantingInstructionItem[]

  @@map("lots")
}

// ============================================================
// PLANTING INSTRUCTIONS
// ============================================================

model PlantingInstruction {
  id            String            @id @default(cuid())
  code          String            @unique
  plantTypeId   String
  plantType     PlantType         @relation(fields: [plantTypeId], references: [id])
  // Môi trường nay chọn riêng theo từng dòng quy cách nguồn (M3/M5) — xem PlantingInstructionItem,
  // vì mỗi quy cách có thể dùng môi trường nhân mẫu mẹ / ra rễ khác nhau.

  createdById   String
  createdBy     User              @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId  String?
  assignedTo    User?             @relation("AssignedTo", fields: [assignedToId], references: [id])

  // Tổng đầu vào/dự kiến cộng dồn từ tất cả các dòng quy cách nguồn (items) — 1 chỉ định có thể dùng nhiều
  // quy cách nguồn (VD: cùng 1 kệ có cả M3 và M5), mỗi dòng tự có tỉ lệ riêng — xem PlantingInstructionItem.
  inputMotherQuantity     Int
  expectedMotherOutput    Int?
  expectedFinishedOutput  Int?

  // Kế hoạch phân bổ thành phẩm dự kiến theo quy cách đóng gói — KY_THUAT nhập lúc tạo chỉ định,
  // tổng nên khớp expectedFinishedOutput. Lô thành phẩm thật sự tạo ra khi NV cấy nhập nhật ký hàng ngày
  // có thể mang quy cách T01 hoặc T05 tùy NV chọn — 2 số này chỉ là kế hoạch để đối chiếu.
  plannedT01Quantity      Int?
  plannedT05Quantity      Int?

  status      InstructionStatus @default(DRAFT)
  weekStart   DateTime?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  items        PlantingInstructionItem[]
  lots         Lot[]
  dailyRecords DailyRecord[]

  @@map("planting_instructions")
}

// 1 dòng = 1 quy cách nguồn (M3 hoặc M5) dùng trong chỉ định. 1 kệ có thể sinh nhiều dòng
// (VD: kệ có cả M3 và M5) vì mỗi quy cách có tỉ lệ nhân/ra rễ riêng.
model PlantingInstructionItem {
  id            String              @id @default(cuid())
  instructionId String
  instruction   PlantingInstruction @relation(fields: [instructionId], references: [id])
  shelfId       String
  shelf         Shelf               @relation(fields: [shelfId], references: [id])
  lotId         String?
  lot           Lot?                @relation(fields: [lotId], references: [id])
  stageCode     String? // "M3" | "M5"
  quantity      Int

  motherSampleRatio      Float?
  rootingRatio           Float?
  expectedMotherOutput   Int?
  expectedFinishedOutput Int?

  // Môi trường riêng cho dòng quy cách này: 1 để nhân thêm mẫu mẹ, 1 để ra rễ thành cây thành phẩm.
  motherMediumTypeId     String?
  motherMedium           MediumType? @relation("ItemMotherMedium", fields: [motherMediumTypeId], references: [id])
  finishedMediumTypeId   String?
  finishedMedium         MediumType? @relation("ItemFinishedMedium", fields: [finishedMediumTypeId], references: [id])

  @@map("planting_instruction_items")
}

// ============================================================
// DAILY RECORDS
// ============================================================

model DailyRecord {
  id            String              @id @default(cuid())
  instructionId String
  instruction   PlantingInstruction @relation(fields: [instructionId], references: [id])
  staffId       String
  staff         User                @relation(fields: [staffId], references: [id])
  recordDate    DateTime            @default(now())
  motherUsed    Int
  notes         String?
  createdAt     DateTime            @default(now())

  items DailyRecordItem[]

  @@map("daily_records")
}

model DailyRecordItem {
  id              String      @id @default(cuid())
  dailyRecordId   String
  dailyRecord     DailyRecord @relation(fields: [dailyRecordId], references: [id])
  lotId           String
  lot             Lot         @relation(fields: [lotId], references: [id])
  stage           PlantStage
  quantityCreated Int

  @@map("daily_record_items")
}

// ============================================================
// CONTAMINATION RECORDS
// ============================================================

model ContaminationRecord {
  id            String    @id @default(cuid())
  lotId         String
  lot           Lot       @relation(fields: [lotId], references: [id])
  quantity      Int
  recordDate    DateTime  @default(now())
  confirmedAt   DateTime?
  confirmedById String?
  notes         String?
  createdAt     DateTime  @default(now())

  @@map("contamination_records")
}

// ============================================================
// TRANSFERS
// ============================================================

model Transfer {
  id              String         @id @default(cuid())
  code            String         @unique
  fromWarehouseId String?
  fromWarehouse   Warehouse?     @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  fromRoomId      String?
  fromRoom        Room?          @relation("TransferFromRoom", fields: [fromRoomId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  toRoomId        String?
  toRoom          Room?          @relation("TransferToRoom", fields: [toRoomId], references: [id])
  fromUserId      String
  fromUser        User           @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUserId        String?
  toUser          User?          @relation("TransferTo", fields: [toUserId], references: [id])
  status          TransferStatus @default(PENDING)
  notes           String?
  transferredAt   DateTime       @default(now())
  confirmedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items TransferItem[]

  @@map("transfers")
}

model TransferItem {
  id         String   @id @default(cuid())
  transferId String
  transfer   Transfer @relation(fields: [transferId], references: [id])
  lotId      String
  lot        Lot      @relation(fields: [lotId], references: [id])
  quantity   Int
  notes      String?

  @@map("transfer_items")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id              String      @id @default(cuid())
  code            String      @unique
  saleId          String
  sale            User        @relation(fields: [saleId], references: [id])
  customerName    String
  customerPhone   String?
  customerAddress String?
  status          OrderStatus @default(DRAFT)
  holdUntil       DateTime?
  confirmedAt     DateTime?
  shippedAt       DateTime?
  cancelledAt     DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  lotId     String
  lot       Lot     @relation(fields: [lotId], references: [id])
  quantity  Int
  unitPrice Float?
  notes     String?

  @@map("order_items")
}

// ============================================================
// ALERTS
// ============================================================

model Alert {
  id          String      @id @default(cuid())
  type        AlertType
  status      AlertStatus @default(UNREAD)
  title       String
  message     String
  userId      String?
  targetRole  UserRole?
  user        User?       @relation(fields: [userId], references: [id])
  relatedId   String?
  relatedType String?
  createdAt   DateTime    @default(now())
  readAt      DateTime?

  @@map("alerts")
}
